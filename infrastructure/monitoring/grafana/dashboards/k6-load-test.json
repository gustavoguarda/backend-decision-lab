        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(k6_http_reqs_total{stack=~\"$stack\", scenario=~\"$scenario\"}[1m])) by (stack)",
          "legendFormat": "{{stack}}"
        }
      ]
