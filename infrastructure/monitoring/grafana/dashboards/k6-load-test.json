{
  "uid": "k6-load-test",
  "title": "k6 Load Test",
  "tags": ["k6", "backend-decision-lab"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "stack",
        "label": "Stack",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(k6_http_reqs_total, stack)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(k6_http_reqs_total, stack)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {},
        "options": [],
        "hide": 0
      },
      {
        "name": "scenario",
        "label": "Scenario",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(k6_http_reqs_total, scenario)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(k6_http_reqs_total, scenario)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {},
        "options": [],
        "hide": 0
      }
    ]
  },
  "annotations": {
