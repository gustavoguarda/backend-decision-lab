# Postgres (shared by every implementation)
POSTGRES_DB=benchmark
POSTGRES_USER=benchmark
POSTGRES_PASSWORD=benchmark

# Connection details injected into each service
DB_HOST=postgres
DB_PORT=5432
DB_NAME=benchmark
DB_USER=benchmark
DB_PASSWORD=benchmark

# Internal HTTP port every service listens on
APP_PORT=8000

# Host port mappings (override if one collides with another process on your machine).
# Internal port is always 8000; these only affect host-side access (curl/browser).
PHP_LARAVEL_PORT=8001
NODE_FASTIFY_PORT=8002
PYTHON_FASTAPI_PORT=8003
GO_GIN_PORT=8004
RUST_AXUM_PORT=8005

# Monitoring stack (profile "monitoring"): host ports + Grafana credentials.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
